# --- Required for `npm run generate` (ranking + drafting via Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional: real email sending via Resend for `npm run send` ---
# If unset, `send` writes an HTML preview to /drafts instead of emailing anyone.
RESEND_API_KEY=
NEWSLETTER_FROM=AI for Marketers <onboarding@resend.dev>

# --- Optional overrides ---
# MAX_AGE_DAYS=10     # ignore feed items older than this many days
# ITEM_TARGET=9       # max items to select per issue (fewer is fine, never padded)
